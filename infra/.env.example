# =============================================================================
# Legal RAG — Environment Variables
# Copy to .env and fill in secrets before running docker compose.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true

# ---------------------------------------------------------------------------
# OpenAI — REQUIRED for LLM and embedding features
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Model settings (optional overrides)
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/federal_law_agent
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@postgres:5432/federal_law_agent
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# QDRANT_API_KEY=            # Only needed for Qdrant Cloud

# Qdrant collection names — change to avoid contamination across environments
QDRANT_FEDERAL_COLLECTION=federal_corpus
QDRANT_DOCUMENT_COLLECTION=uploaded_documents
QDRANT_CFR_COLLECTION=cfr_corpus

# ---------------------------------------------------------------------------
# Federal U.S. Code XML Corpus
# ---------------------------------------------------------------------------
# Path (inside the container) where USLM XML files are mounted
FEDERAL_XML_BASE_PATH=/data/xml

# Which U.S. Code titles to ingest (comma-separated or JSON array)
FEDERAL_TITLES=[11,18]

# ---------------------------------------------------------------------------
# CFR Corpus (Code of Federal Regulations) — Week 2
# ---------------------------------------------------------------------------
# Which CFR titles to ingest (complement U.S. Code titles above)
# 26 = Treasury/IRS regulations (implements IRC Title 26)
# 29 = Labor regulations (implements FLSA, ERISA — Title 29)
CFR_TITLES=[26,29]

# Local directory (inside the container) to cache downloaded CFR XML
CFR_DOWNLOAD_DIR=/data/cfr_xml

# CFR publication year to download from govinfo.gov bulk data
CFR_YEAR=2024

# ---------------------------------------------------------------------------
# Document Upload
# ---------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=[".pdf",".docx",".txt"]

# ---------------------------------------------------------------------------
# Retrieval Tuning
# ---------------------------------------------------------------------------
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.65
RETRIEVAL_RERANK_TOP_K=5

# ---------------------------------------------------------------------------
# Case Law Corpus (CourtListener) — Week 3
# ---------------------------------------------------------------------------
# Free research-use token from https://www.courtlistener.com/sign-in/
COURTLISTENER_API_KEY=your_token_here

# Qdrant collection for judicial opinions
QDRANT_CASE_LAW_COLLECTION=case_law_corpus

# Max precedential opinions to fetch per USC title (pagination capped here)
CASE_LAW_MAX_OPINIONS_PER_TITLE=500

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
