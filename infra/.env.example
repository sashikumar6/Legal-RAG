# Application
APP_NAME=Federal Law & Document AI Intake Agent
APP_VERSION=0.2.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
# For local dev: postgresql+asyncpg://postgres:postgres@localhost:5432/federal_law_agent
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/federal_law_agent
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5433/federal_law_agent
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_FEDERAL_COLLECTION=federal_corpus
QDRANT_DOCUMENT_COLLECTION=uploaded_documents
DEV_QDRANT_LOCAL_MODE=false

# LLM
# Replace with your actual OpenAI API Key
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Federal Corpus
FEDERAL_XML_BASE_PATH=/path/to/your/xml/data
FEDERAL_TITLES=[8,11,15,18,26,28,29,42]

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Retrieval
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.35

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Next.js Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
